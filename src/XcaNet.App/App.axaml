<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pageViewModels="using:XcaNet.App.ViewModels.Pages"
             xmlns:pages="using:XcaNet.App.Views.Pages"
             x:Class="XcaNet.App.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://XcaNet.App/Styles/ThemeResources.axaml" />
  </Application.Styles>
  <Application.DataTemplates>
    <DataTemplate DataType="pageViewModels:DashboardPageViewModel">
      <pages:DashboardPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:CertificatesPageViewModel">
      <pages:CertificatesPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:PrivateKeysPageViewModel">
      <pages:PrivateKeysPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:CertificateRequestsPageViewModel">
      <pages:CertificateRequestsPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:CertificateRevocationListsPageViewModel">
      <pages:CertificateRevocationListsPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:TemplatesPageViewModel">
      <pages:TemplatesPageView />
    </DataTemplate>
    <DataTemplate DataType="pageViewModels:SettingsSecurityPageViewModel">
      <pages:SettingsSecurityPageView />
    </DataTemplate>
  </Application.DataTemplates>
</Application>
