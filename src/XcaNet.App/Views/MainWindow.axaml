<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XcaNet.App.ViewModels"
        x:Class="XcaNet.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="960"
        Height="540"
        MinWidth="720"
        MinHeight="420"
        Title="{Binding Title}">
  <Grid RowDefinitions="Auto,*" Margin="32">
    <StackPanel Spacing="8">
      <TextBlock FontSize="32"
                 FontWeight="SemiBold"
                 Text="{Binding Title}" />
      <TextBlock Classes="dim"
                 FontSize="18"
                 Text="{Binding Subtitle}" />
    </StackPanel>

    <Grid Grid.Row="1"
          Margin="0,24,0,0"
          ColumnDefinitions="2*,3*"
          ColumnSpacing="20">
      <Border Padding="24"
              Background="#112233"
              CornerRadius="16">
        <StackPanel Spacing="12">
          <TextBlock FontSize="20" FontWeight="SemiBold" Text="Database Lifecycle" />
          <TextBlock Text="Database Path" />
          <TextBox Text="{Binding DatabasePath}" />
          <TextBlock Text="Display Name" />
          <TextBox Text="{Binding DisplayName}" />
          <TextBlock Text="Master Password" />
          <TextBox PasswordChar="*" Text="{Binding Password}" />

          <WrapPanel Margin="0,12,0,0" HorizontalAlignment="Left">
            <Button Margin="0,0,8,8" Command="{Binding CreateDatabaseCommand}" Content="Create" />
            <Button Margin="0,0,8,8" Command="{Binding OpenDatabaseCommand}" Content="Open" />
            <Button Margin="0,0,8,8" Command="{Binding UnlockDatabaseCommand}" Content="Unlock" />
            <Button Margin="0,0,8,8" Command="{Binding LockDatabaseCommand}" Content="Lock" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Padding="24"
              Background="#18363C"
              CornerRadius="16">
        <StackPanel Spacing="12">
          <TextBlock FontSize="20" FontWeight="SemiBold" Text="Status" />
          <TextBlock TextWrapping="Wrap" Text="{Binding StatusMessage}" />
          <TextBlock FontWeight="SemiBold" Text="Current Session" />
          <TextBlock Text="{Binding Snapshot.DatabasePath}" />
          <TextBlock Text="{Binding Snapshot.DisplayName}" />
          <TextBlock Text="{Binding Snapshot.State}" />
          <TextBlock Text="{Binding Snapshot.SchemaVersion}" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
