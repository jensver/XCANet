<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XcaNet.App.Views.Pages.CertificateRevocationListsPageView">
  <StackPanel Spacing="14">
    <Border Background="White" CornerRadius="12" Padding="16">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Certificate Revocation Lists" FontSize="18" FontWeight="SemiBold" />
          <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}" />
        </Grid>
        <TextBlock Text="{Binding PlaceholderMessage}" Foreground="#475569" TextWrapping="Wrap" />
        <ListBox ItemsSource="{Binding Items}" Height="420">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8">
                <Grid ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="10">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{Binding CreatedUtc}" />
                  <TextBlock Grid.Column="2" Text="{Binding NextUpdateUtc}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
