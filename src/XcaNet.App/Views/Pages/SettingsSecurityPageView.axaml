<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XcaNet.App.Views.Pages.SettingsSecurityPageView">
  <Grid ColumnDefinitions="1.1*,1*" ColumnSpacing="16">
    <Border Classes="surface-card" Padding="16">
      <StackPanel Spacing="12">
        <TextBlock Text="Database Lifecycle" FontSize="18" FontWeight="SemiBold" />
        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
          <TextBlock Text="Database Path" />
          <TextBox Grid.Column="1" Text="{Binding DatabasePath}" />
          <TextBlock Grid.Row="1" Text="Display Name" />
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DisplayName}" />
          <TextBlock Grid.Row="2" Text="Password" />
          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Password}" PasswordChar="*" />
          <TextBlock Grid.Row="3" Text="State" />
          <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SessionState}" />
          <TextBlock Grid.Row="4" Text="Last Opened" />
          <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastOpened}" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Button Content="Create" Command="{Binding CreateDatabaseCommand}" />
          <Button Content="Open" Command="{Binding OpenDatabaseCommand}" />
          <Button Content="Unlock" Command="{Binding UnlockDatabaseCommand}" />
          <Button Content="Lock" Command="{Binding LockDatabaseCommand}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Grid.Column="1" Classes="surface-card" Padding="16">
      <StackPanel Spacing="12">
        <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold" />
        <Border Classes="info-panel" Padding="12">
          <TextBlock Text="{Binding StatusMessage}" Classes="secondary-text" TextWrapping="Wrap" />
        </Border>
        <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
          <TextBlock Text="Managed Backend" />
          <TextBlock Grid.Column="1" Text="{Binding ManagedBackendStatus}" />
          <TextBlock Grid.Row="1" Text="OpenSSL Backend" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OpenSslBackendStatus}" TextWrapping="Wrap" />
          <TextBlock Grid.Row="2" Text="OpenSSL Version" />
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OpenSslVersion}" />
          <TextBlock Grid.Row="3" Text="Capabilities" />
          <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OpenSslCapabilities}" TextWrapping="Wrap" />
          <TextBlock Grid.Row="4" Text="Routing" />
          <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RoutingSummary}" TextWrapping="Wrap" />
          <TextBlock Grid.Row="5" Text="App Version" />
          <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AppVersion}" />
          <TextBlock Grid.Row="6" Text="Schema Version" />
          <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SchemaVersion}" />
        </Grid>
        <TextBlock Text="Private keys remain encrypted at rest. Unlock is required before key creation, signing, revocation, or export operations." Classes="secondary-text" TextWrapping="Wrap" />
        <TextBlock Text="Diagnostics are informational only. Backend routing is unchanged and the managed backend remains the default." Classes="secondary-text" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
