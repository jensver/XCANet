<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XcaNet.App.Views.Pages.CertificatesPageView">
  <Grid ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
    <StackPanel Spacing="14">
      <Border Background="White" CornerRadius="12" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Search and Filter" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,180,180,Auto" ColumnSpacing="10">
            <TextBox Watermark="Search name, subject, issuer, serial, thumbprint" Text="{Binding SearchText}" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding ValidityFilters}" SelectedItem="{Binding SelectedValidityFilter}" />
            <ComboBox Grid.Column="2" ItemsSource="{Binding AuthorityFilters}" SelectedItem="{Binding SelectedAuthorityFilter}" />
            <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="White" CornerRadius="12" Padding="12">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Certificates" FontSize="18" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Export Selected" Command="{Binding ExportSelectedCommand}" />
          </Grid>
          <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Height="320">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8">
                  <Grid ColumnDefinitions="2.4*,1.4*,1.3*,Auto" ColumnSpacing="12">
                    <StackPanel>
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Subject}" Foreground="#475569" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Issuer}" TextWrapping="Wrap" />
                    <TextBlock Grid.Column="2" Text="{Binding RevocationStatus}" />
                    <TextBlock Grid.Column="3" Text="{Binding KeyAlgorithm}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Background="White" CornerRadius="12" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Import Material" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,180,180" ColumnSpacing="10">
            <TextBox Watermark="Display name" Text="{Binding ImportDisplayName}" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding ImportKinds}" SelectedItem="{Binding SelectedImportKind}" />
            <ComboBox Grid.Column="2" ItemsSource="{Binding ImportFormats}" SelectedItem="{Binding SelectedImportFormat}" />
          </Grid>
          <TextBox Text="{Binding ImportPassword}" PasswordChar="*" Watermark="Import password when needed" />
          <TextBox Text="{Binding ImportPayload}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" Watermark="Paste PEM, DER-as-base64, PKCS#10, PKCS#12 or key material here." />
          <Button Content="Import" HorizontalAlignment="Left" Command="{Binding ImportMaterialCommand}" />
        </StackPanel>
      </Border>
    </StackPanel>

    <StackPanel Grid.Column="1" Spacing="14">
      <Border Background="White" CornerRadius="12" Padding="16">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
            <TextBlock Text="Certificate Inspector" FontSize="18" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Open Issuer" Command="{Binding OpenIssuerCommand}" />
            <Button Grid.Column="2" Content="Open Key" Command="{Binding OpenPrivateKeyCommand}" />
            <Button Grid.Column="3" Content="Open Child" Command="{Binding OpenChildCertificateCommand}" />
          </Grid>
          <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <TextBlock Text="Display Name" />
            <TextBlock Grid.Column="1" Text="{Binding Inspector.DisplayName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="Subject" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Inspector.Subject}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="Issuer" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Inspector.IssuerDisplayName}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="3" Text="Serial" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Inspector.SerialNumber}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="Not Before" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Inspector.NotBefore}" />
            <TextBlock Grid.Row="5" Text="Not After" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Inspector.NotAfter}" />
            <TextBlock Grid.Row="6" Text="SHA-1" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Inspector.Sha1Thumbprint}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="7" Text="SHA-256" />
            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Inspector.Sha256Thumbprint}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="8" Text="Key Algorithm" />
            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Inspector.KeyAlgorithm}" />
            <TextBlock Grid.Row="9" Text="CA Status" />
            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Inspector.CertificateAuthorityStatus}" />
            <TextBlock Grid.Row="10" Text="Revocation" />
            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding Inspector.RevocationStatus}" />
            <TextBlock Grid.Row="11" Text="Private Key" />
            <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding Inspector.PrivateKeyDisplayName}" />
          </Grid>

          <TextBlock Text="Subject Alternative Names" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Inspector.SubjectAlternativeNames}" TextWrapping="Wrap" />
          <TextBlock Text="Key Usage" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Inspector.KeyUsage}" TextWrapping="Wrap" />
          <TextBlock Text="Enhanced Key Usage" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Inspector.EnhancedKeyUsage}" TextWrapping="Wrap" />
          <TextBlock Text="Child Certificates" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding Inspector.ChildCertificates}" SelectedItem="{Binding Inspector.SelectedChildCertificate}" />
        </StackPanel>
      </Border>

      <Border Background="White" CornerRadius="12" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Export Preview" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="180,*" ColumnSpacing="10">
            <ComboBox ItemsSource="{Binding ExportFormats}" SelectedItem="{Binding SelectedExportFormat}" />
            <TextBox Grid.Column="1" Text="{Binding SelectedExportPassword}" PasswordChar="*" Watermark="Optional export password for PKCS#12" />
          </Grid>
          <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" Height="180" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
